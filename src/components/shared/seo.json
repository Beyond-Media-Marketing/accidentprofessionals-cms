{
  "collectionName": "components_shared_seos",
  "info": {
    "displayName": "SEO",
    "icon": "search",
    "description": "Per-page SEO metadata"
  },
  "options": {},
  "attributes": {
    "metaTitle": {
      "type": "string",
      "maxLength": 60
    },
    "metaDescription": {
      "type": "text",
      "maxLength": 160
    },
    "focusKeyword": {
      "type": "string"
    },
    "keywords": {
      "type": "string"
    },
    "canonicalUrl": {
      "type": "string"
    },
    "ogImage": {
      "type": "media",
      "multiple": false,
      "allowedTypes": ["images"]
    },
    "noindex": {
      "type": "boolean",
      "default": false
    },
    "nofollow": {
      "type": "boolean",
      "default": false
    },
    "schemaType": {
      "type": "enumeration",
      "enum": ["WebPage", "AboutPage", "ContactPage", "Service", "CollectionPage", "FAQPage"],
      "default": "WebPage"
    }
  }
}
